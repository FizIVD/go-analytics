      "title": "User Registration Funnel",
      "type": "flant-statusmap-panel",
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "query": "SELECT 'Step 1' as step, count(distinct profile_id) as users FROM events.events_raw WHERE action = 'register_step_1' UNION ALL SELECT 'Step 2' as step, count(distinct profile_id) as users FROM events.events_raw WHERE action = 'register_step_2' UNION ALL SELECT 'Step 3' as step, count(distinct profile_id) as users FROM events.events_raw WHERE action = 'register_step_3' UNION ALL SELECT 'Step 4' as step, count(distinct profile_id) as users FROM events.events_raw WHERE action = 'register_step_4' UNION ALL SELECT 'Step 5' as step, count(distinct profile_id) as users FROM events.events_raw WHERE action = 'register_step_5' UNION ALL SELECT 'Step 6' as step, count(distinct profile_id) as users FROM events.events_raw WHERE action = 'register_step_6' UNION ALL SELECT 'Step 7' as step, count(distinct profile_id) as users FROM events.events_raw WHERE action = 'register_step_7'"
        }
      ]
    },
