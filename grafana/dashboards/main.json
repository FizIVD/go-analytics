      },
      "title": "Retention for First Minute Users",
      "type": "table",
      "targets": [
        {
          "refId": "A",
          "datasource": "ClickHouse",
          "query": "WITH (SELECT min(event_time) FROM events.events_raw) AS first_event_time SELECT toDate(event_time) AS day, count(DISTINCT profile_id) AS active_users FROM events.events_raw WHERE profile_id IN (SELECT DISTINCT profile_id FROM events.events_raw WHERE event_time >= first_event_time AND event_time < first_event_time + INTERVAL 1 MINUTE) GROUP BY day ORDER BY day"
        }
      ]
    }
